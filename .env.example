# ==================================
# Docker Environment Template
# ==================================
# Copy this file to .env and update the values

# MongoDB Configuration
# ====================
# Root user credentials
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=your_secure_mongo_password
MONGO_INITDB_DATABASE=mydb

# MongoDB Express (Web UI)
# =======================
# Web interface credentials
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=your_secure_express_password

# MongoDB Exporter (for Prometheus)
# ===============================
MONGODB_EXPORTER_ENABLED=true

# SQL Server Configuration
# =======================
MSSQL_SA_PASSWORD=YourStrong!Passw0rd
MSSQL_PID=Developer
MSSQL_TCP_PORT=1433
MSSQL_SSMS_PORT=1434
MSSQL_DATA_DIR=/var/opt/mssql/data
MSSQL_LOG_DIR=/var/opt/mssql/log
MSSQL_BACKUP_DIR=/var/opt/mssql/backup
MSSQL_ACCEPT_EULA=Y

# Resource Limits
# ==============
# MongoDB
MONGODB_MEMORY_LIMIT=2G
MONGODB_MEMORY_RESERVATION=1G
MONGODB_CPU_LIMIT=2
MONGODB_CPU_RESERVATION=1

# SQL Server
MSSQL_MEMORY_LIMIT=4G
MSSQL_MEMORY_RESERVATION=2G
MSSQL_CPU_LIMIT=2
MSSQL_CPU_RESERVATION=1

# Ports
# =====
MONGODB_EXPRESS_PORT=8081

# Note: Always keep this file out of version control
# and never commit actual credentials to your repository.
# Add .env to your .gitignore file.
